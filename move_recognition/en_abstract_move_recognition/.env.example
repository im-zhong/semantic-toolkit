# Zhipu AI API Key Configuration
# Get your API key at https://open.bigmodel.cn/

# Method 1: Use environment variable (recommended)
# export ZHIPU_API_KEY="your_actual_api_key_here"

# Method 2: Copy this file to .env and fill in your key
# cp .env.example .env
# Then edit .env file with your actual API key

ZHIPU_API_KEY="your_actual_api_key_here"
